diff --git a/backend/add_cloudinary_columns.py b/backend/add_cloudinary_columns.py
new file mode 100644
index 0000000..ca081e2
--- /dev/null
+++ b/backend/add_cloudinary_columns.py
@@ -0,0 +1,53 @@
+
+import os
+import sys
+import psycopg2
+
+# Add parent directory to path so we can import db_config
+sys.path.append(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
+
+from backend import db_config
+
+def migrate():
+    print("Starting migration: Adding cloudinary columns to dprs table...")
+    
+    conn = db_config.get_connection()
+    cursor = db_config.get_cursor(conn, dict_cursor=False)
+    
+    try:
+        # Check if columns exist
+        cursor.execute("""
+            SELECT column_name 
+            FROM information_schema.columns 
+            WHERE table_name='dprs' AND column_name='cloudinary_url'
+        """)
+        if cursor.fetchone():
+            print("Column 'cloudinary_url' already exists. Skipping.")
+        else:
+            print("Adding 'cloudinary_url' column...")
+            cursor.execute("ALTER TABLE dprs ADD COLUMN cloudinary_url TEXT")
+            
+        cursor.execute("""
+            SELECT column_name 
+            FROM information_schema.columns 
+            WHERE table_name='dprs' AND column_name='cloudinary_public_id'
+        """)
+        if cursor.fetchone():
+            print("Column 'cloudinary_public_id' already exists. Skipping.")
+        else:
+            print("Adding 'cloudinary_public_id' column...")
+            cursor.execute("ALTER TABLE dprs ADD COLUMN cloudinary_public_id TEXT")
+            
+        conn.commit()
+        print("✓ Migration completed successfully.")
+        
+    except Exception as e:
+        conn.rollback()
+        print(f"✗ Migration failed: {e}")
+        raise
+    finally:
+        cursor.close()
+        db_config.release_connection(conn)
+
+if __name__ == "__main__":
+    migrate()
