diff --git a/create_dummy_dpr.py b/create_dummy_dpr.py
new file mode 100644
index 0000000..9bbad43
--- /dev/null
+++ b/create_dummy_dpr.py
@@ -0,0 +1,80 @@
+
+import os
+import sys
+import json
+from datetime import datetime
+
+# Add parent directory to path so we can import db_config
+sys.path.append(os.path.dirname(os.path.abspath(__file__)))
+
+from backend import db_config
+
+def create_dummy():
+    print("Creating dummy DPR...")
+    conn = db_config.get_connection()
+    cursor = db_config.get_cursor(conn, dict_cursor=False)
+    
+    try:
+        # Create a dummy project first
+        cursor.execute("""
+            INSERT INTO projects (name, state, scheme, sector, created_at)
+            VALUES ('Demo Project', 'Maharashtra', 'Test Scheme', 'Roads', NOW())
+            RETURNING id
+        """)
+        project_id = cursor.fetchone()[0]
+        
+        # Create dummy DPR
+        summary = {
+            "overallScore": 85,
+            "recommendation": "Shortlist for Next Phase",
+            "tenderDetails": {
+                "tenderName": "Construction of Highway 42",
+                "tenderReferenceNumber": "TN-2024-HW42",
+                "bidderName": "Acme Construction Ltd",
+                "projectLocation": {"city": "Pune", "state": "Maharashtra", "country": "India"}
+            },
+            "technicalEvaluation": {
+                "projectTimeline": {
+                    "proposedDuration": "24 Months",
+                    "isTimelineRealistic": True,
+                    "milestones": ["Phase 1: Planning", "Phase 2: Execution"]
+                },
+                "methodologyAndApproach": {
+                    "strengths": ["Robust Plan", "Experienced Team"],
+                    "weaknesses": []
+                }
+            }
+        }
+        
+        cursor.execute("""
+            INSERT INTO dprs (
+                project_id, filename, original_filename, filepath, uploaded_file_ref, 
+                upload_ts, summary_json, status, cloudinary_url
+            )
+            VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s)
+            RETURNING id
+        """, (
+            project_id, 
+            "dummy_file.pdf", 
+            "Dummy_Proposal_v1.pdf", 
+            "/tmp/dummy.pdf", 
+            "ref_123", 
+            datetime.now(), 
+            json.dumps(summary), 
+            "completed",
+            "http://example.com/dummy.pdf"
+        ))
+        
+        dpr_id = cursor.fetchone()[0]
+        conn.commit()
+        print(f"✓ Created Dummy DPR with ID: {dpr_id}")
+        
+    except Exception as e:
+        conn.rollback()
+        print(f"✗ Failed to create dummy: {e}")
+    finally:
+        cursor.close()
+        db_config.release_connection(conn)
+
+if __name__ == "__main__":
+    create_dummy()
